
select * ,
avg(salary) over (partition by department_id ) 
as avg_dept_sal
from employees

select *,
sum(amount) over(order by order_date rows between 
unbounded preceding and current row)
as total_com_sales
from orders

select students student_id, student_name,
class_id, marks,
max(marks) over (partition by class_id)
as high_marks
from students

select *,
sum(sales) over(partition by category_id)
as total_sales
from products

select * ,
rank() over(partition by department_id 
order by salary desc)
as emp_rank
from employees

select *,
avg(salary) over(partition by department_id) 
as dept_avg_sal
from employees

select * ,
avg(amount) 
over(order by order_date rows between 2
preceding and current row)
as moving_avg
from orders

select * ,
sum(sales) 
over(partition by category_id) 
as category_sales,
(sales * 100 / sum(sales) 
over(partition by category_id))
as perc_cate_sales
from products

select * ,
rank()
over(order by salary desc) as emp_rank
from employees

-----------------------------------------------------

SELECT *
FROM (
    SELECT emp_id, emp_name, department_id, salary,
           RANK() OVER(PARTITION BY department_id ORDER BY salary DESC) AS sal_rank
    FROM employees
) ranked
WHERE sal_rank <= 3;


select * 
from(
select emp_id, emp_name,
department_id, salary,
rank() over(partition by department_id
order by salary desc) as high_sal_emp
from employees ) 
ranked --name of this sub-query
where high_sal_emp = 2

select * 
from( select emp_id, emp_name, department_id, salary , 
rank() over(partition by department_id 
order by salary desc) as high_sal
from employees )
ranked --name of this sub-query
where high_sal = 3

select * 
from (select  emp_id, emp_name, 
department_id, salary,
rank () over(order by salary) as high_sal
from employees)
ranked -- sub-query name
where high_sal <= 5
----------------------------------------------------
qoes - 12
select * ,
lag(amount) 
over(order by order_date )
as each_order,
amount - lag(amount) over(order by order_date ) 
 as diffrence
from orders

select * ,
lead(amount)
over(order by order_date) as next_ord_amt
from orders

select * ,
max(marks)
over(order by exam_date 
rows between unbounded preceding and current row)
as high_marks
from students

select * ,
percent_rank()
over(order by salary) as percentile_rank
from employees

select * 
from(
select emp_id, emp_name,
department_id, salary, dense_rank()
over(partition by department_id
order by salary desc)
as high_sal
from employees)
ranked
where high_sal <= 3

select * ,
avg(salary)
over(partition by department_id) as avg_sal
from employees
where salary > avg(salary)
over(partition by department_id)

select * 
from (select emp_id, emp_name, department_id, salary,
dense_rank() over(order by salary) as sal_rank
from employees)
ranked
where sal_rank = 2

select * from
(select emp_id, emp_name, department_id, salary,
max(salary) over(partition by department_id) 
as max_sal from employees )
ranked
where salary = max_sal
