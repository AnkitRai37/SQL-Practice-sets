create table department(
dept_id int primary key,
dept_name varchar(50),
location varchar(50)
)

insert into department
values
(1,'HR','New York'),
(2,'IT','London'),
(3,'Finance','Chicago'),
(4,'Sales','Boston')

create table employees(
emp_id int primary key,
emp_name varchar(100),
dept_id int,
manager_id int,
salary int,
hire_date date
)


